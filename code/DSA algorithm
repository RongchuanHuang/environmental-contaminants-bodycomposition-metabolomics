# DSA_example.R
# Example: DSA variable selection across multiple outcomes and random seeds

library(DSA)
 
# Define your data (replace 'your_data' with your dataframe)
# Data should contain outcome variables and all candidate exposure variables
outcomes  <- c("Out1", "Out2", "Out3")   # replace with your outcome names
exposures <- paste0("Exp", 1:97)         # replace with your exposure variable names

# Set random seeds for stability analysis
seeds <- sample(1:10000, 1000, replace = FALSE)

# Run DSA for each outcome and seed
dsa_results <- list()
for (out in outcomes) {
  dsa_results[[out]] <- list()
  for (s in seeds) {
    data_temp <- your_data[, c(out, exposures)]
    formula   <- as.formula(paste(out, "~ 1"))
    
    dsa_results[[out]][[as.character(s)]] <- DSA(
      formula      = formula,
      data         = data_temp,
      maxsize      = 10,
      maxorderint  = 1,
      maxsumofpow  = 1,
      vfold        = 5,
      family       = "gaussian",
      seed         = s
    )
  }
}
