# CIT_example.R
# Example: Causal Inference Test (CIT) for mediation analysis
# Replace 'your_data' with your actual dataframe
 
library(cit)
library(dplyr)
 
# Define your covariates (same set as in LME modeling)
covariates <- c("Age", "BMI", "DietScore", "Gender", "Education",
                "Smoke", "Drink", "Exercise", "Group",
                "Hypertension", "Hyperlipidemia", "Diabetes")

