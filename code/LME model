exposure  <- "PFHxS" 
covariates <- c("Age", "BMI", "DietScore", "Gender", "Education",
                "Smoke", "Drink", "Exercise", "Group",
                "Hypertension", "Hyperlipidemia", "Diabetes")

# Build model formula (fixed effects + random intercept)
formula <- as.formula(
  paste0(outcome, " ~ ", exposure, " + ",
         paste(covariates, collapse = " + "),
         " + (1 | ID)")
)

# Fit linear mixed model
model <- lmer(formula, data = analysis_data, na.action = na.omit)
 
 
